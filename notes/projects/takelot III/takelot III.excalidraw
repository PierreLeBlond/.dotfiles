      "seed": 2012754218,
      "version": 535,
      "versionNonce": 903691446,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773396568711,
      "link": null,
      "locked": false,
      "text": "Puzzle game where you play a mummy trying to escape a pyramid.\nTo find your way out, you have to switch between three save files, corresponding to three moment in time, \nplaying as Takelot I, II and III.\nYou're playing the game three time at once, and some action you take with Takelot I and II will persist between save/time, and help Takelot III progress.",
      "fontSize": 20,
      "fontFamily": 7,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Puzzle game where you play a mummy trying to escape a pyramid.\nTo find your way out, you have to switch between three save files, corresponding to three moment in time, \nplaying as Takelot I, II and III.\nYou're playing the game three time at once, and some action you take with Takelot I and II will persist between save/time, and help Takelot III progress.",
      "autoResize": true,
      "lineHeight": 1.15
    },
