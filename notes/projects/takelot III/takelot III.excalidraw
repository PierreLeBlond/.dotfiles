    {
      "id": "YHpfIMznKum5TxWjxbE8q",
      "type": "text",
      "x": 805.7643419901519,
      "y": -342.4225185976019,
      "width": 1293.5,
      "height": 92,
      "angle": 0,
      "strokeColor": "#1e1e1e",
